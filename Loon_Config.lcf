# --- BoxJs（需 MITM）---
# https://github.com/chavyleung/scripts/raw/master/box/rewrite/boxjs.rewrite.loon.plugin, policy=✈️ 策略选择, tag=BoxJs, enabled=false

# --- Sub-Store ---
# https://raw.githubusercontent.com/Peng-YM/Sub-Store/master/config/Loon.plugin, policy=✈️ 策略选择, tag=Sub-Store, enabled=false

# ============================================================
# [Mitm] MITM 中间人解密配置
# ============================================================
[MITM]

hostname =
skip-server-cert-verify = false

